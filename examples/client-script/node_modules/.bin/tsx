else
  export NODE_PATH="/home/arthur/Documents/Hackaton/BSA_EPFL_HACKATON_21_03_2026/HACKATON_x402/node_modules/.pnpm/tsx@4.21.0/node_modules/tsx/node_modules:/home/arthur/Documents/Hackaton/BSA_EPFL_HACKATON_21_03_2026/HACKATON_x402/node_modules/.pnpm/tsx@4.21.0/node_modules:/home/arthur/Documents/Hackaton/BSA_EPFL_HACKATON_21_03_2026/HACKATON_x402/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../tsx/dist/cli.mjs" "$@"
else
  exec node  "$basedir/../tsx/dist/cli.mjs" "$@"
fi
